---
//@ts-nocheck
import DynamicImage from "@components/helpers/DynamicImage.astro";
import caseStudy from "@data/caseStudy.json";
const { caseName, category, date, image, buttonLabel } = caseStudy.caseDetails;
import ButtonLink from "./ButtonLink.astro";
---

<article>
  <header>
    <DynamicImage imagePath={image} altText={caseName} />
    <div class="case-details">
      <dl>
        <div>
          <dt>Case Name</dt>
          <dd>{caseName}</dd>
        </div>
        <div>
          <dt>Category</dt>
          <dd class="category">{category}</dd>
        </div>
        <div>
          <dt>Date</dt>
          <dd class="date">{date}</dd>
        </div>
      </dl>
      <ButtonLink href="/priser" variant="yellow_link">Live Preview</ButtonLink>
    </div>
  </header>
  {
    caseStudy.sections.map((section) => (
      <section>
        {caseStudy.sections[0] === section ? (
          <h2>{section.title}</h2>
        ) : (
          <h3>{section.title}</h3>
        )}

        {Array.isArray(section.content) ? (
          <>
            {section.content.map((item) => (
              <p>{item}</p>
            ))}
          </>
        ) : (
          <p>{section.content}</p>
        )}
        {section.highlights && (
          <ul>
            {section.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        )}
        {section.image && (
          <DynamicImage
            imagePath={section.image}
            altText={section.title}
            width={600}
            height={400}
          />
        )}
      </section>
    ))
  }
</article>

<style>
  @layer components {
    header {
      display: grid;
      img {
        overflow: clip;
        border-radius: var(--border-radius-2);
      }
    }
    .case-details {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;

      transform: translateY(-50%);

      background-color: var(--color-ui-primary);
      color: var(--color-on-ui-primary);
      border-radius: var(--border-radius-2);

      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      padding: 2.5rem;
      gap: 2rem;
    }

    .case-details dl {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin: 0;
    }

    .case-details dl div {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    article {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      margin-bottom: var(--space-sections);
    }

    article > * {
      grid-column: content;

      p {
        color: var(--color-text-muted);
        font-size: var(--p-size);
      }
      h2 {
        font-size: var(--h2-size);
        margin-bottom: var(--space-heading);
      }
      h3 {
        font-size: var(--h3-size);
        margin-bottom: var(--space-heading);
      }
      ul {
        line-height: var(--space-ordered-list);
        color: var(--color-text-muted);
      }
      img {
        display: block;
        margin: 2rem auto; /* centrerer horisontalt */
        max-width: 100%;
        height: auto;
      }
    }
    article > section {
      max-width: 675px;
      margin-inline: auto;
    }
  }
</style>
