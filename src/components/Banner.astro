---
const { title, subtitle, description, linePosition = "left" } = Astro.props;
---

<section class={`banner ${linePosition}`}>
  <div class="card_banner">
    <span class="eyebrow">{subtitle}</span>
    <h1>{title}</h1>
    <p>{description}</p>
  </div>
</section>

<style>
  @layer components {
    .banner {
      background: var(--color-neutrals-100);
      padding-block: 6rem;
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      position: relative;
    }

    .banner > * {
      grid-column: content;
    }

    .banner::before {
      content: "";
      position: absolute;
      height: 5px;
      width: 38%;
      background: var(--color-action);
      top: 48.5%;
      transform: translateY(-50%);
    }

    .banner.left1::before {
      left: 0;
    }

    .banner.left2::before {
      left: 0;
      width: 40%;
    }

    .banner.right::before {
      right: 0;
    }

    @media (max-width: 600px) {
      .banner::before {
        top: 45.2%;
        width: 16%;
      }

      .banner.right::before {
        right: 0;
        width: 20%;
      }
    }

    .card_banner {
      max-width: 700px;
      margin: auto;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 1rem;

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.8rem;
        color: var(--color-text-muted);
      }

      h1 {
        font-size: var(--h2-size);
        position: relative;
        display: inline-block;

        text-decoration: underline solid var(--color-action);
        text-decoration-thickness: 5px;
        text-underline-offset: 6px;
      }

      p {
        font-size: var(--p-size);
        color: var(--color-neutrals-700);
      }
    }
  }
</style>
