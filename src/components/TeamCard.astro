---
const { Employees } = Astro.props;
import ButtonLink from "./ButtonLink.astro";
---

<section class="team_section">
  <div class="team_intro">
    <div class="text">
      <h2>Meet Our Great Team</h2>

      <p>
        Welcome to our amazing team! We are a group of passionate individuals
        dedicated to excellence and innovation. Each member brings unique skills
        and experiences.
      </p>
    </div>

    <ButtonLink variant="black_link">Join our team</ButtonLink>
  </div>

  <div class="team_grid">
    {
      Employees.map((employee: any) => (
        <article class="team_card">
          <a href={`/singlepage/${employee.slug}`} class="team_card_link">
            <div class="image_wrapper">
              <img src={employee.img} alt={employee.name} />
              <span class="role">{employee.title}</span>
            </div>

            <h5>{employee.name}</h5>

            <p>{employee.description}</p>
          </a>
          <div class="socials">
            {employee.social_links.map((link: any) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                <img
                  src={`/src/icons/${link.platform}.svg`}
                  alt={link.platform}
                  width="24"
                  height="24"
                />
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  @layer components {
    .team_section {
      padding: 4rem 2rem;
      display: grid;
      grid-template-columns: subgrid;
      grid-column: content;
      gap: 3rem;
    }

    .team_intro {
      grid-column: 1 / -1;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .team_intro .text {
      flex: 1 1 60%;
      min-width: 250px;
    }

    .team_intro ButtonLink {
      flex-shrink: 0;
    }

    .team_grid {
      grid-column: 1 / -1;

      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }

    .team_card {
      display: grid;
      grid-row: span 4;
      text-align: center;
    }

    .image_wrapper {
      position: relative;

      img {
        width: 100%;
        border-radius: 20px;
        display: block;
      }

      .role {
        position: absolute;
        bottom: 10px;
        right: 10px;
        background: var(--color-ui-primary);
        color: var(--color-on-ui-primary);
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
      }
    }

    .team_card h5 {
      margin: 0.3rem 0;
      font-size: var(--h5-size);
    }

    .team_card p {
      margin: 0.3rem 0;
      font-size: 0.9rem;
    }

    .socials {
      gap: 5px;
      margin-top: 0.3rem;
    }

    h2 {
      font-family: var(--header-font);
      font-size: var(--h2-size);
    }

    h5 {
      font-family: var(--header-font);
      font-size: var(--h5-size);
    }

    p {
      color: var(--color-text-muted);
      font-family: var(--font-text);
      font-size: var(--p-size);
      max-width: 500px;
    }

    .socials {
      display: flex;
      justify-content: center;
      gap: 10px;
    }
  }
</style>
