---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
import ButtonLink from "./ButtonLink.astro";
---

<section class="hero">
  <div class="hero-left">
    <div class="hero-content">
      <h1>Empowering Your Business Growth</h1>
      <p>
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>

      <div class="hero-buttons">
        <ButtonLink href="/priser" variant="yellow_link"
          >Book a Meeting</ButtonLink
        >
        <ButtonLink href="/priser" variant="border_link"
          >Learn More →</ButtonLink
        >
      </div>
    </div>
  </div>

  <div class="hero-right">
    <Image src={CEOImage} alt="CEO" />
  </div>

  <Services />
</section>

<style>
  h1 {
    font-size: var(--h1-size);
    font-weight: 700;
  }

  @layer components {
    .hero {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
    }
    .hero-left {
      grid-column: full-start / content-mid;
      background: #020617;
      color: white;
      display: grid;
      grid-template-columns: subgrid;
    }

    .hero-content {
      grid-column: content-start;
      padding-top: 4rem;
      padding-right: 2rem;
      padding-bottom: 10rem; /* mere sort område */
      h1 {
        margin-bottom: var(--space-heading);
      }
      p {
        margin-bottom: var(--space-heading);
        color: var(--color-on-ui-primary-muted);
      }
    }

    .hero-right {
      grid-column: content-mid / full-end;
    }

    .hero-right img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-buttons {
      display: flex;
      > * + * {
        margin-left: 1rem;
      }
    }
  }
</style>
