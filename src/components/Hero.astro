---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero">
  <div class="hero-left">
    <div class="hero-content">
      <h1>Empowering Your Business Growth</h1>
      <p>
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>

      <div class="hero-buttons">
        <a class="btn-primary" href="#0">Book a Meeting</a>
        <a class="btn-secondary" href="#0">Learn More →</a>
      </div>
    </div>
  </div>

  <div class="hero-right">
    <Image src={CEOImage} alt="CEO" />
  </div>

  <Services />
</section>

<style>
  /* Styles her */
  @layer components {
    .hero {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      gap: 0px;
    }
    .hero-left {
      grid-column: full-start / content-mid;
      background: #020617;
      color: white;
    }

    .hero-content {
      grid-column: content-start;
      max-width: 60ch;
      padding: 4rem 2rem;
    }

    /* højre side */
    .hero-right {
      grid-column: content-mid / full-end;
    }

    .hero-right img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }
</style>
