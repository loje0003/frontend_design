---
import coreValues from "@data/coreValues.json";
import ButtonLink from "./ButtonLink.astro";
import DynamicIcon from "./helpers/DynamicIcon.astro";

const { title, theme = "default" } = Astro.props;
---

<section class="coreValues_section" data-surface={theme}>
  <div class="text_intro">
    <div class="text">
      <p class="eyebrow">{coreValues.eyebrow}</p>
      <h2>{coreValues.title}</h2>
      <p>
        {coreValues.subtitle}
      </p>
    </div>
    <ButtonLink variant="contrasted">Get in touch</ButtonLink>
  </div>

  <div class="cards_grid">
    {
      coreValues.values.map((item) => (
        <article class="card">
          <a href={item.link.url} class="card_link">
            <div class="icon">
              <DynamicIcon name={item.icon} />
            </div>

            <h3>{item.title}</h3>

            <p>{item.description}</p>

            <ButtonLink variant="black_ghost_link">Read More →</ButtonLink>
          </a>
        </article>
      ))
    }
  </div>
</section>

<style>
  @layer components {
    p {
      font-family: var(--font-text);
      font-size: var(--p-size);
      color: var(--text);
    }

    h2 {
      font-family: var(--font-text);
      font-size: var(--h2-size);
      color: var(--text);
    }
    .icon {
      background-color: var(--color-neutrals-900);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #eaeaea;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.8rem;
      margin-bottom: 0.5rem;
    }

    .coreValues_section {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      padding-block: 4rem;
      background: var(--bg);
    }
    .coreValues_section > * {
      grid-column: content;
    }

    .text_intro {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }

    .text_intro .text {
      max-width: 560px;
    }

    .cards_grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2rem;
    }

    .card {
      background: #eaeaea;
      border-radius: 20px;
      padding: var(--border-radius-1);
      align-self: start;
      margin-top: 1rem;
      background: var(--card-bg);

      p {
        font-family: var(--font-text);
        font-size: var(--p-size);
        color: var(--color-neutrals-700);
      }

      h2 {
        font-family: var(--font-text);
        font-size: var(--h2-size);
        color: var(--color-neutrals-900);
      }
    }
  }
  [data-surface="default"] {
    --bg: var(--color-surface-secondary);
    --text: var(--color-text);
    --card-bg: var(--color-surface-primary);
    --bg-button: #000;
    --color-button: #eaeaea;
  }

  [data-surface="dark"] {
    --bg: var(--color-neutrals-900);
    --text: var(--color-on-ui-primary);
    --card-bg: var(--color-surface-secondary);
    --bg-button: #eaeaea;
    --color-button: #000;
  }
</style>
