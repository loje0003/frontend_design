---
import financialProjections from "@data/financialProjections.json";
import DynamicIcon from "./helpers/DynamicIcon.astro";
---

<section class="financial-section">
  <p class="eyebrow">{financialProjections.eyebrow}</p>
  <h2>{financialProjections.title}</h2>
  <p>{financialProjections.subtitle}</p>

  <ul class="cards_grid">
    {
      financialProjections.values.map((item) => (
        <li class="card">
          <a href={item.link.url} class="card_link">
            <div class="icon">
              <DynamicIcon name={item.icon} />
            </div>

            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  @layer components {
    p {
      font-family: var(--font-text);
      font-size: var(--p-size);
    }

    h2 {
      font-family: var(--font-text);
      font-size: var(--h2-size);
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.8rem;
      margin-bottom: 0.5rem;
    }

    .financial-section {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      padding-block: 4rem;
      background-color: var(--color-neutrals-100);
      > * {
        grid-column: content;
      }
      > ul {
        scroll-snap-type: x mandatory;
        grid-column: content;
        padding-inline: max(1rem, 50% - var(--content-width) / 2);
        padding-block-end: 1rem;

        li {
          scroll-snap-align: center;
        }
      }
    }

    .cards_grid {
      list-style: none;
      margin: 0;
      padding: 0;

      grid-column: full;
      padding-inline: max(1rem, 50% - var(--content-width) / 2);

      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 280px;
      gap: 10px;

      overflow-x: auto;
    }
  }

  .card {
    background: #eaeaea;
    border-radius: 20px;
    padding: var(--border-radius-1);
    align-self: start;
    margin-top: 1rem;
  }
</style>
