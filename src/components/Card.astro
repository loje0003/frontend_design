---
import { Image } from "astro:assets";
import Checkmark from "../icons/checkmark.svg";

const {
  title,
  subtitle,
  description,
  point1,
  point2,
  image,
  reverse = false,
} = Astro.props;
---

<section class={`card ${reverse ? "card--reverse" : ""}`}>
  <div class="card_image">
    {image && <Image src={image} alt={title} />}
  </div>

  <div class="card_content">
    <span class="eyebrow">{subtitle}</span>
    <h2>{title}</h2>

    <p>{description}</p>

    <ul class="check">
      <li><Checkmark class="icon" /> {point1}</li>
      <li><Checkmark class="icon" /> {point2}</li>
    </ul>
  </div>
</section>

<style>
  @layer components {
    .card {
      margin-top: var(--space-sections);
      margin-bottom: var(--space-sections);
      display: grid;
      grid-template-columns: subgrid;
      grid-column: content;
      gap: 64px;

      img {
        border-radius: var(--border-radius-1);
      }

      > * + * {
        gap: 64px;
      }

      h2 {
        font-size: var(--h2-size);
        font-family: var(--font-header);
        font-weight: var(--weight-header-regular);
      }
      p {
        font-size: var(--p-size);
        color: var(--color-neutrals-700);
        padding: 10px;
      }
    }

    .card--reverse {
      direction: rtl;
      text-align: right;
      gap: 64px;
    }

    .card--reverse .card_content {
      direction: ltr;
      text-align: left;
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    li {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.8rem;
      color: var(--color-neutrals-700);
      padding-top: 15px;

      .icon {
        width: 16.69px;
        height: 16.69px;
        color: var(--color-ui-secondary-alternative);
        flex-shrink: 0;
      }
    }

    .card_image {
      position: relative;
      isolation: isolate;
      &::before {
        content: "";
        position: absolute;
        top: -2rem;
        left: -2rem;
        width: 183px;
        border-radius: var(--border-radius-1);
        height: 164px;
        background: var(--color-ui-secondary);
        z-index: -1;
      }
    }

    @media (max-width: 768px) {
      section {
        grid-template-columns: 1fr;
        margin: 30px;
      }

      .card_image {
        grid-column: 1 / 3;
        grid-row: 1/2;
      }

      .card_content {
        grid-column: 1 / 3;
        grid-row: 2 /3;
        width: 100%;
      }
    }
  }
</style>
